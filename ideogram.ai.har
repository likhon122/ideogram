            "size": 10490,
            "mimeType": "application/json",
            "text": "{\"results\":[{\"user\":{\"user_id\":\"lFJrDL4wSMOFa7wfMdI5UA\",\"photo_url\":\"https:\\/\\/ideogram.ai\\/api\\/images\\/default\\/default_profile_image\",\"display_handle\":\"totinikhatun268\",\"subscription_plan_id\":\"o-sIa28SQSGZzKlMLZjDkA\",\"badge\":null},\"user_prompt\":\"Defibrillator Readiness: Close-up of a doctor\\u2019s gloved hands holding defibrillator paddles, charging them up in a chaotic emergency room environment. The background is slightly blurred with nurses and a patient monitor showing a flatline. Intense contrast, cinematic lighting, sharp focus on the medical instruments.\",\"user_negative_prompt\":\"\",\"private\":true,\"request_id\":\"ZZhtrtsIQLaCcpHMAI2WDA\",\"request_type\":\"TEXT_TO_IMAGE\",\"responses\":[{\"response_id\":\"RWqGmzITRMGbF31cfS3xMQ\",\"prompt\":\"A doctor's blue-gloved hands grip black defibrillator paddles, thumbs positioned over the charge buttons. The paddles' metal surfaces catch harsh fluorescent light. Blurred emergency room behind shows nurses moving and a flatline on a patient monitor. Bright overhead surgical lighting creates sharp shadows across the gloved fingers and paddle handles. Shot at chest level, close focus on the hands and equipment. Medical photograph.\",\"self_like\":false,\"num_likes\":0,\"highest_fidelity\":true,\"pin_on_profile\":false,\"cover\":true,\"is_autoprompt\":true,\"private\":true,\"descriptions\":[],\"tags\":[],\"response_index\":0,\"references\":{\"style\":[{\"type\":\"preset_style_type\",\"name\":\"Realistic\",\"deleted\":false,\"style_type\":\"REALISTIC\"}]},\"category_id\":\"BqEAaCr-T-eH52OvESCHrw\"}],\"creation_time_float\":1776653317.943782,\"resolution\":1024,\"height\":736,\"width\":1312,\"user_hparams\":{\"style\":\"AUTO\",\"aspect_ratio\":\"16:9\"},\"seed\":653440321,\"aspect_ratio\":\"16:9\",\"model_version\":\"V_3_1\",\"model_uri\":\"model\\/V_3_1\\/version\\/0\",\"cover_response_id\":\"RWqGmzITRMGbF31cfS3xMQ\",\"autoprompt_loading\":false,\"use_autoprompt\":false,\"is_completed\":true,\"is_errored\":false,\"sampling_speed\":-2,\"max_upscale_factor\":8,\"can_upscale\":true,\"image_resolution\":\"1K\",\"expected_number_of_final_responses\":1,\"character_reference_collection_ids\":[],\"product_reference_collection_ids\":[],\"references\":{\"style\":[{\"type\":\"preset_style_type\",\"name\":\"Auto\",\"deleted\":false,\"style_type\":\"AUTO\"}]},\"style_reference_collection_ids\":[],\"style_expert\":\"AUTO\",\"use_random_style_codes\":false,\"category_id\":\"BqEAaCr-T-eH52OvESCHrw\",\"caption\":\"Defibrillator Readiness: Close-up of a doctor\\u2019s gloved hands holding defibrillator paddles, charging them up in a chaotic emergency room environment. The background is slightly blurred with nurses and a patient monitor showing a flatline. Intense contrast, cinematic lighting, sharp focus on the medical instruments.\"},{\"user\":{\"user_id\":\"lFJrDL4wSMOFa7wfMdI5UA\",\"photo_url\":\"https:\\/\\/ideogram.ai\\/api\\/images\\/default\\/default_profile_image\",\"display_handle\":\"totinikhatun268\",\"subscription_plan_id\":\"o-sIa28SQSGZzKlMLZjDkA\",\"badge\":null},\"user_prompt\":\"ER Waiting Room: A wide shot of a clean, modern hospital waiting room at night. A worried family sits together on comfortable blue chairs while a compassionate triage nurse in green scrubs speaks to them softly. Soft ambient lighting, calming architectural elements, highly detailed commercial stock photography, 8k resolution\",\"user_negative_prompt\":\"\",\"private\":true,\"request_id\":\"-tCCLxcSRUWtU5AYNS3Rlg\",\"request_type\":\"TEXT_TO_IMAGE\",\"responses\":[{\"response_id\":\"Ve_0aQ_6R6CGOEkGRzdzOA\",\"prompt\":\"A family of three sits on blue upholstered chairs in a modern hospital waiting room, leaning toward each other. A nurse in green scrubs kneels beside them, gesturing gently as she speaks. Clean white walls with wood accent panels, polished floors reflecting overhead lights. Soft fluorescent lighting creates even illumination with mini