# Required auth/config from your Ideogram session
IDEOGRAM_USER_ID=
IDEOGRAM_COOKIE=
IDEOGRAM_ORG=r2AQ-Mr3QUqo198XsOmg4g

# Optional auth header if your account/API flow requires it
IDEOGRAM_BEARER_TOKEN=

# HAR header replay defaults
IDEOGRAM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/147.0.0.0 Safari/537.36
IDEOGRAM_ACCEPT_LANGUAGE=en-US,en;q=0.9,bn;q=0.8
IDEOGRAM_ACCEPT_ENCODING=gzip, deflate, br, zstd
IDEOGRAM_SEC_CH_UA="Google Chrome";v="147", "Not.A/Brand";v="8", "Chromium";v="147"
IDEOGRAM_SEC_CH_UA_MOBILE=?0
IDEOGRAM_SEC_CH_UA_PLATFORM="Windows"
IDEOGRAM_SEC_FETCH_DEST=empty
IDEOGRAM_SEC_FETCH_MODE=cors
IDEOGRAM_SEC_FETCH_SITE=same-origin
IDEOGRAM_REQUEST_PRIORITY=u=1, i
IDEOGRAM_AMPLITUDE_SESSION_ID=

# Generation defaults captured from HAR
IDEOGRAM_MODEL_VERSION=V_3_1
IDEOGRAM_MODEL_URI=model/V_3_1/version/0
IDEOGRAM_STYLE_TYPE=AUTO
IDEOGRAM_CATEGORY_ID=BqEAaCr-T-eH52OvESCHrw
IDEOGRAM_USE_AUTOPROMPT_OPTION=ON
IDEOGRAM_SAMPLING_SPEED=-2
IDEOGRAM_PRIVATE=true
IDEOGRAM_NUM_IMAGES=1
IDEOGRAM_RESOLUTION_WIDTH=1312
IDEOGRAM_RESOLUTION_HEIGHT=736

# Upscale defaults captured from HAR
IDEOGRAM_UPSCALE_FACTOR=X4
IDEOGRAM_UPSCALE_FACTOR_8K=X8
IDEOGRAM_SUPER_RES_MODEL_VERSION=AUTO
IDEOGRAM_SUPER_RES_MODEL_URI=model/AUTO/version/0
IDEOGRAM_SUPER_RES_INTERNAL=true
IDEOGRAM_SUPER_RES_USE_AUTOPROMPT_OPTION=OFF

# Runtime behavior
IDEOGRAM_API_BASE_URL=https://ideogram.ai
IDEOGRAM_POLL_INTERVAL_MS=3000
IDEOGRAM_REQUEST_TIMEOUT_MS=120000
IDEOGRAM_MAX_WAIT_MS=360000
IDEOGRAM_OUTPUT_DIR=outputs

# Startup behavior
IDEOGRAM_ENABLE_QUOTA_PREFLIGHT=true

# Cloudflare 403 handling: retries via real local browser session
IDEOGRAM_ENABLE_BROWSER_FALLBACK=true
IDEOGRAM_BROWSER_HEADLESS=false
IDEOGRAM_BROWSER_EXECUTABLE_PATH=
IDEOGRAM_BROWSER_WARMUP_PATH=/library/my-images
IDEOGRAM_BROWSER_WARMUP_TIMEOUT_MS=45000

# Optional custom headers as JSON object string
# Example: {"x-some-header":"value"}
IDEOGRAM_EXTRA_HEADERS_JSON=
